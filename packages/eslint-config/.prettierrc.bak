{
    "printWidth": 100,
    "useTabs": false,
    "singleQuote": true,
    "trailingComma": "none",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "jsxBracketSameLine": false,
    "arrowParens": "avoid",
    "singleAttributePerLine": true,
    "htmlWhitespaceSensitivity": "strict"
}
